APP_ENV=development
RUNTIME_DIR=.runtime
DATABASE_URL=postgresql+psycopg://quant:quant@localhost:5432/quant_system
REDIS_URL=redis://localhost:6379/0
DEFAULT_EXCHANGE=binance
DEFAULT_SYMBOL=BTCUSDT
DEFAULT_MARKET_TYPE=futures
DEFAULT_ACCOUNT_MODE=paper
PRIMARY_TIMEFRAME=5m
AUX_TIMEFRAME=15m
PAPER_INITIAL_EQUITY=10000
PAPER_INITIAL_MARGIN_RATIO=0.1
MAKER_FEE_BPS=2
TAKER_FEE_BPS=4
SLIPPAGE_BPS=3
BINANCE_PROXY=
OPENCLAW_READ_ONLY=true
RISK_POLICY_PATH=shared/config/risk_policy.json
RISK_POLICY_OVERRIDES_JSON=
INTERNAL_API_ALLOWED_HOSTS=127.0.0.1,localhost,testclient
ALLOW_REMOTE_INTERNAL_API=false
ENABLE_LIVE_EXECUTION=false
